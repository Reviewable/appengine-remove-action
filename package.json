{
  "name": "appengine-remove",
  "version": "4.1.0",
  "packageManager": "yarn@4.13.0",
  "description": "Github Action: Remove versions from Google App Engine",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist/ && ncc build --source-map --no-source-map-register src/main.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "check-types": "tsc --noEmit --skipLibCheck",
    "update": "yarn up -R '*' && yarn dedupe --strategy highest",
    "latest": "yarn npm-check-updates -i -m --packageManager yarn --install never && yarn install",
    "upgrade": "reviewable-upgrade",
    "format": "prettier --write src/*.ts"
  },
  "keywords": [
    "actions",
    "google cloud",
    "app engine",
    "deploy"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^1.2.6",
    "@actions/exec": "^1.0.3",
    "@actions/tool-cache": "^2.0.1",
    "@google-github-actions/setup-cloud-sdk": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^10.7.0",
    "globals": "^16.5.0",
    "npm-check-updates": "^22.0.0",
    "prettier": "^3",
    "reviewable-configs": "Reviewable/reviewable-configs#master",
    "ts-node": "^10.9.1",
    "typescript": "^5"
  }
}
